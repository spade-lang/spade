struct A {
    x: bool,
    y: int<3>
}

extern fn takes_normal(x: bool, y: int<3>) -> bool;

entity uut(val: inv &A) -> bool {
    let x = inst read_mut_wire(val.x);
    let y = inst read_mut_wire(val.y);
    takes_normal(x, y)
}


